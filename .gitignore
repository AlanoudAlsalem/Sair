# ═══════════════════════════════════════════════
# SairAI .gitignore
# ═══════════════════════════════════════════════

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.so

# ── Virtual environment ──────────────────────
venv/
env/
.venv/
.env/

# ── IDE / Editor ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── macOS ────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# ── Windows ──────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── YOLOv8 model weights ────────────────────
# These are large binary files (6–130 MB).
# Users should download them via ultralytics.
*.pt
*.onnx
*.engine
*.torchscript
runs/

# ── Video files ──────────────────────────────
# Drone footage is too large for Git.
# Users should add their own videos locally.
data/videos/*.mp4
data/videos/*.mov
data/videos/*.avi
data/videos/*.mkv
data/videos/*.wmv

# ── Output files ─────────────────────────────
data/output/

# ── Lane definitions ─────────────────────────
# Per-video lane JSONs are generated locally.
# Users should recreate for their own footage.
data/lanes/

# ── Logs ─────────────────────────────────────
*.log
logs/

# ── Jupyter notebooks checkpoints ────────────
.ipynb_checkpoints/

# ── Environment variables ────────────────────
.env
.env.local
.env.production

# ── PyTorch / CUDA cache ────────────────────
*.pth
torch_extensions/
